{
  "rewrites": [
    {
      "source": "/demo",
      "destination": "/demo.html"
    },
    {
      "source": "/bz",
      "destination": "/bz.html"
    },
    {
      "source": "/intake/:slug",
      "destination": "/api/intake?slug=:slug"
    },
    {
      "source": "/tetris/:slug",
      "destination": "/tetris/:slug.html"
    }
  ],
  "headers": [
    {
      "source": "/workshop-videos/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "video/mp4" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
