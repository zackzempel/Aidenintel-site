{
  "rewrites": [
    {
      "source": "/demo",
      "destination": "/demo.html"
    },
    {
      "source": "/bz",
      "destination": "/bz.html"
    },
    {
      "source": "/intake/:slug",
      "destination": "/api/intake?slug=:slug"
    },
    {
      "source": "/tetris/:slug",
      "destination": "/tetris/:slug.html"
    }
  ]
}